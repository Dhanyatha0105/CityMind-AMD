# CityMind Configuration
# Copy to .env and fill in your values

# LLM Provider (openai, ollama, or anthropic)
LLM_PROVIDER=openai
OPENAI_API_KEY=your-key-here

# Ollama (if using local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# AMD Ryzen AI NPU settings (for Windows Ryzen AI deployment)
USE_NPU=false
VITIS_AI_EP=false
VAIP_CONFIG_PATH=models/vaip_config.json

# Processing settings
MAX_FRAMES=50
FRAME_EXTRACTION_FPS=3
BLUR_THRESHOLD=100
DEPTH_MODEL=depth-anything/Depth-Anything-V2-Small-hf
DETECTION_MODEL=yolov8m.pt
DEFECT_MODEL=yolov8m.pt

# 3D Reconstruction
COLMAP_PATH=colmap
USE_GPU_RECONSTRUCTION=false

# Output
OUTPUT_DIR=output
REPORT_FORMAT=pdf
